# ─── Server ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── Database ────────────────────────────────────────────────────────────────
# Local MongoDB (default — works if you have MongoDB installed)
MONGODB_URI=mongodb://127.0.0.1:27017/mindmate

# Or use a free MongoDB Atlas cluster:
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/mindmate?retryWrites=true&w=majority

# ─── Auth ────────────────────────────────────────────────────────────────────
# Change this to a long random string in production!
# Generate one: openssl rand -hex 64
JWT_SECRET=mindmate_super_secret_key_change_in_production

# ─── Frontend URL ────────────────────────────────────────────────────────────
# Used in password-reset email links
FRONTEND_URL=http://localhost:3000

# ─── Email — OPTIONAL ────────────────────────────────────────────────────────
# Without these the app still works fully:
#   - In development, reset tokens and verification codes are printed to the console
#   - In production without email, the token is not exposed (users must configure email)
#
# To enable real Gmail sending:
#   1. Go to: Google Account → Security → 2-Step Verification → App Passwords
#   2. Create an App Password for "Mail"
#   3. Paste the 16-character password below (no spaces)
EMAIL_USER=your_gmail@gmail.com
EMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx
