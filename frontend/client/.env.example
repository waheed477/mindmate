# ─── Vite dev server port ────────────────────────────────────────────────────
VITE_PORT=3000

# ─── Backend URL (for Vite proxy) ────────────────────────────────────────────
# Must match the PORT in backend/.env
# Vite proxies /api/* and /socket.io/* to this address
BACKEND_URL=http://localhost:5000
