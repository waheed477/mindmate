# Copy this file to .env and fill in your values
# DO NOT commit .env to GitHub

# MongoDB — local Compass / Atlas
MONGODB_URI=mongodb://localhost:27017/mindmate

# Server port
PORT=5000

# JWT — use any long random string (min 32 chars)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Gmail App Password for email verification
# Get from: Google Account → Security → 2-Step Verification → App Passwords
EMAIL_USER=your-email@gmail.com
EMAIL_APP_PASSWORD=your-16-char-app-password

# Frontend URL (used in password reset emails)
FRONTEND_URL=http://localhost:3000
