# Copy this file to .env and fill in your values
# DO NOT commit .env to GitHub

# MongoDB — local Compass
MONGODB_URI=mongodb://localhost:27017/mindmate

# Server port
PORT=3001

# JWT — use any long random string
JWT_SECRET=your-super-secret-jwt-key-change-this

# Gmail for email verification
EMAIL_USER=your-email@gmail.com
EMAIL_APP_PASSWORD=your-16-char-gmail-app-password

# Optional: frontend URL for password reset links
FRONTEND_URL=http://localhost:5000
